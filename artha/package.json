{
  "name": "artha-ai",
  "version": "0.1.0",
  "description": "ARTHA AI — AI-native financial operating system for Indian MSMEs",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/api",
    "start": "npm run start --workspace=apps/api",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js --ignore-path .gitignore",
    "lint:fix": "eslint . --ext .js --ignore-path .gitignore --fix",
    "format": "prettier --write .",
    "migrate": "npm run migrate --workspace=packages/database",
    "migrate:down": "npm run migrate:down --workspace=packages/database",
    "migrate:status": "npm run migrate:status --workspace=packages/database"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "moduleNameMapper": {
      "^@artha/config$": "<rootDir>/packages/config/src/index.js",
      "^@artha/logger$": "<rootDir>/packages/logger/src/index.js",
      "^@artha/errors$": "<rootDir>/packages/errors/src/index.js",
      "^@artha/database$": "<rootDir>/packages/database/src/index.js",
      "^@artha/session$": "<rootDir>/packages/session/src/index.js"
    },
    "coverageDirectory": "coverage",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ],
    "testTimeout": 15000
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}