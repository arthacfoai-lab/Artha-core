# ─────────────────────────────────────────────────────────────────
# ARTHA AI — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (PostgreSQL) ─────────────────────────────────────────
DATABASE_URL=postgresql://artha:artha_dev@localhost:5432/artha_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_SESSION_TTL_SECONDS=3600

# ── JWT ───────────────────────────────────────────────────────────
# Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET_MINIMUM_32_CHARS
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ── Security ──────────────────────────────────────────────────────
# Shared secret between ARTHA and OpenClaw / Paperclip webhooks
WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_SECRET_MINIMUM_16_CHARS
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=pretty

# ── App Metadata ──────────────────────────────────────────────────
APP_VERSION=0.1.0
APP_NAME=artha-api